# ============================================================
# Build artifacts
# ============================================================
**/target/
**/pkg/
**/dist/
**/build/

# ============================================================
# Python
# ============================================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.venv/
**/.coverage
**/htmlcov/
**/.pytest_cache/
**/*.egg-info/
*.spec

# ============================================================
# Node / JavaScript
# ============================================================
**/node_modules/
**/.pnpm-store/
**/package-lock.json

# ============================================================
# Rust
# ============================================================
**/Cargo.lock

# ============================================================
# IDE & OS
# ============================================================
.vscode/settings.json
*.code-workspace
.DS_Store
Thumbs.db

# ============================================================
# Environment & secrets
# ============================================================
**/.env
**/.env.local
**/.env.*.local

# ============================================================
# Databases & backups
# ============================================================
**/*.db
**/*.db.backup_*
**/*.sql.gz

# ============================================================
# Logs & temp files
# ============================================================
**/*.log
**/imgui.ini
**/imgui_log.txt
debug.log

# ============================================================
# Project-specific generated / ephemeral
# ============================================================
cache/
downloads/
backups/
storage/perf_test/
storage/test_storage/
storage/game_data/settings.json
storage/game_data/saves/player.json
storage_config.json


# Test outputs (generated, not source)
test_output_*.txt
test_output_*.json

# ============================================================
# Server static assets (built from web client)
# ============================================================
apps/server/static/ui/
!apps/server/static/ui/.gitkeep
# Legacy paths kept during migration
server_host/static/ui/
!server_host/static/ui/.gitkeep

# ============================================================
# Compendiums — allow only loaders, not large data exports
# ============================================================
core_table/compendiums/tokens/*
!core_table/compendiums/*loader.py
core_table/compendiums/exports/*
packages/core-table/compendiums/tokens/*
!packages/core-table/compendiums/*loader.py
packages/core-table/compendiums/exports/*

# ============================================================
# Legacy / archived directories
# ============================================================
legacy/desktop_client/sdl3/
legacy/desktop_client/profiling/
legacy/desktop_client/trash/


# ============================================================
# Docs (internal; tracked separately if needed)
# ============================================================
docs/

# Server internal
server_host/doc/
