{
  "title": "TTRPG User Journey",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {"id": 1, "type": "timeseries", "title": "HTTP request rate by status class", "targets": [{"expr": "sum by (status_class) (rate(ttrpg_http_requests_total[5m]))"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}},
    {"id": 2, "type": "timeseries", "title": "HTTP latency percentiles", "targets": [{"legendFormat": "p50", "expr": "histogram_quantile(0.50, sum by (le) (rate(ttrpg_http_request_duration_seconds_bucket[5m])))"}, {"legendFormat": "p95", "expr": "histogram_quantile(0.95, sum by (le) (rate(ttrpg_http_request_duration_seconds_bucket[5m])))"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}},
    {"id": 3, "type": "timeseries", "title": "WebSocket connection outcomes", "targets": [{"expr": "sum by (outcome, reason) (rate(ttrpg_websocket_connections_total[5m]))"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}},
    {"id": 4, "type": "timeseries", "title": "Asset operation outcomes", "targets": [{"expr": "sum by (operation, outcome) (rate(ttrpg_asset_operations_total[5m]))"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}},
    {"id": 5, "type": "timeseries", "title": "Browser errors by release class", "targets": [{"expr": "sum by (event_type, release) (rate(ttrpg_browser_errors_total[5m]))"}], "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}}
  ]
}
