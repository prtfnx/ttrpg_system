{
  "name": "@ttrpg/rust-core",
  "version": "0.1.0",
  "private": true,
  "main": "pkg/ttrpg_rust_core.js",
  "types": "pkg/ttrpg_rust_core.d.ts",
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "build:release": "wasm-pack build --release --target web --out-dir pkg",
    "test": "cargo test",
    "test:wasm": "cargo test --target wasm32-unknown-unknown --test wasm",
    "test:all": "cargo test && cargo test --target wasm32-unknown-unknown --test wasm",
    "bench": "cargo bench --bench collision_bench"
  }
}
